module Drill.D05DataTypes.TreeToList where

import Drill.D05DataTypes.Tree (Tree (..))

-- | 二分木を中順走査（左→根→右）でリスト化する。
-- 二分探索木の場合、結果は昇順になる。
-- 例:
--   treeToList Leaf                                        == []
--   treeToList (Node Leaf 1 Leaf)                         == [1]
--   treeToList (Node (Node Leaf 1 Leaf) 2 (Node Leaf 3 Leaf)) == [1, 2, 3]
treeToList :: Tree a -> [a]
treeToList = undefined
