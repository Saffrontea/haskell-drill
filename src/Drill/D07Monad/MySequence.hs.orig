module Drill.D07Monad.MySequence where

-- | Maybe のリストを「全員成功」または「1 つでも失敗したら全体失敗」に変換する。
-- （Data.Maybe や Control.Monad の sequence / mapM を使わずに再帰で実装すること）
--
-- 例:
--   mySequence [Just 1, Just 2, Just 3]        == Just [1, 2, 3]
--   mySequence [Just 1, Nothing, Just 3]       == Nothing
--   mySequence []                              == Just []
mySequence :: [Maybe a] -> Maybe [a]
mySequence = undefined
